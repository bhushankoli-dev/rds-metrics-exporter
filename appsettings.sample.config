<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="AWSCredentials" 
     type="System.Configuration.NameValueSectionHandler" />
  </configSections>

  <AWSCredentials>
    <!-- Add your AWS account credentials here -->
    <add key="Account1AccessKey" value="YOUR_ACCESS_KEY_HERE" />
    <add key="Account1SecretKey" value="YOUR_SECRET_KEY_HERE" />
    <add key="Account2AccessKey" value="YOUR_ACCESS_KEY_HERE" />
    <add key="Account2SecretKey" value="YOUR_SECRET_KEY_HERE" />
    <!-- Add more accounts as needed -->
  </AWSCredentials>

  <appSettings>
    <!-- Define the sequence of metrics -->
    <add key="MetricSequence" 
     value="CPUUtilization,DatabaseConnections,FreeStorageSpace,
            ReadLatency,WriteLatency,ReadIOPS,WriteIOPS,
            ReadThroughput,WriteThroughput,DBLoadCPU,DBLoadNonCPU,
            EBSIOBalance%,CPUSurplusCreditBalance,
            CPUSurplusCreditsCharged,NetworkReceiveThroughput,
            NetworkTransmitThroughput,CPUCreditUsage,CPUCreditBalance,
            DiskQueueDepth,FreeableMemory,DBLoad,SwapUsage,
            EBSByteBalance%,BurstBalance" />

    <!-- Binary configuration: 1=enabled, 0=disabled -->
    <!-- Each position maps to MetricSequence order -->
    <add key="BinaryConfiguration" value="111111111111111111111111" />

    <!-- Time granularity: "second", "minute", or "hour" -->
    <add key="TimeGranularity" value="Hour" />
  </appSettings>
</configuration>
